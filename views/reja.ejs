<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>First Project with EXPRESS and EJS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="background-color: #b8b8b8;">
    <div class="container">
         <h1 class="display-4 text-center py-1 pt-5">REJA VA MAQSADLAR</h1>

        <div class="jumbotron p-3 shadow-sm mt-5 bg-light" style="border-radius: 25px;">
            <form id="create-form" action="/create-item" method="POST">
                <div class="d-flex align-items-center">
                <input 
                type="text" 
                name="reja" 
                id="create-field"
                autofocus
                autocomplete="off"
                class="form-control me-5"
                style="flex: 1; font-size:24px"
                />
                <button class="btn btn-primary" style="border-radius: 25px; padding: 10px 25px;">
                    Yangi Reja Qoshish
                </button>
                </div>
            </form>
        </div>


        <ul id="item-list" class="list-group pb-5" style="margin-top: 20px;">
             <%  items.map(function(item) { %>
    <li class="list-group-item list-group-item-info d-flex align-items-center justify-content-between">
     <span class="item-text"><%=item.reja%></span>
     <div>
        <button
        data-id="<%=item._id%>" 
        class="edit-me btn btn-secondary btn-sm mr-1">
         Ozgartirish
        </button>
        <button 
        data-id="<%=item._id%>" 
        class="delete-me btn btn-danger btn-sm">
         Ochirish
        </button>
     </div>
    </li>
            <%  }) %>
        </ul>

        <button id="clean-all" class="btn btn-danger" style="border-radius: 20px; margin-top: 20px; " >
            Hamma Rejalarni Ochirish
        </button>
    </div>

    <script src="https://unpkg.com/axios/dist/axios.min.js"></script>
    <script src="/browser.js"></script>
</body>
</html>